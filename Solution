
with new as(select 
                distinct user_id, 
                reaction as dominant_reaction, 
                count(content_id) over(partition by user_id) as total,
                round((count(reaction) over(partition by user_id,reaction) /count(user_id)   over(partition by user_id)),2) as reaction_ratio

from reactions)

select user_id, 
       dominant_reaction, 
       reaction_ratio from new
where reaction_ratio>=0.6 and 
      total>=5
order by reaction_ratio DESC, 
         user_id ASC; 








